.cr_run.env

# Development signing keys (private only — public PEM may be committed)
.nanokat/keys/*private*.pem
.nanokat/keys/*secret*

# Dependencies and runtime junk
node_modules/
__pycache__/
*.pyc
.venv*/
.venv-mcp/

