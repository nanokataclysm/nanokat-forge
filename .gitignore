apps/orchestrator/orchestrator@1.0.0
*.tgz
*.tar.gz
*.zip

# Editor / agent scratch
.firecrawl/
.qwen/
.idea/
.vscode/
*.swp
*~

# Local backups and one-off dumps
backup/
*.bak.*
*.before-*
apps/orchestrator/**/*.bak.*
apps/orchestrator/**/*.before-*

