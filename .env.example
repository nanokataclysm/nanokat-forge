# NANOKAT Forge — environment template
# Copy to .env (or apps/orchestrator/.env.cloudrun.local) and fill in real values.
# NEVER commit .env files — they are gitignored.

# Required — Alibaba Cloud Model Studio / DashScope (live inference)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Required — demo API gate (header x-nanokat-demo-token / session path)
DEMO_SHARED_SECRET=

# Optional — live orchestrator (defaults shown match apps/orchestrator/server.mjs)
QWEN_MODEL=qwen-plus
NODE_ENV=development
FORCE_SECURE_COOKIES=false
DEBUG_ERRORS=false
# Cloud Run / local listen (FC_CUSTOM_LISTEN_PORT wins if set; else PORT; else 9000)
PORT=9000

# Optional — CLI smoke target (apps/orchestrator/scripts/smoke-cli.mjs)
FORGE_URL=http://localhost:9000

# Optional experimental only — apps/orchestrator/src/agents/models.mjs (smoke/agent matrix).
# Not required for Cloud Run plan → approve → preview. Defaults there are qwen3.7-plus
# if unset; leave blank unless you are working that path intentionally.
# QWEN_NAVIGATOR_MODEL=
# QWEN_RESEARCHER_MODEL=
# QWEN_DOMAIN_MODEL=
# QWEN_HUMAN_FACTORS_MODEL=
# QWEN_OPTIMIST_MODEL=
# QWEN_SKEPTIC_MODEL=
# QWEN_FORECASTER_MODEL=
# QWEN_SYNTHESIZER_MODEL=
# QWEN_VALIDATOR_MODEL=
# QWEN_REPAIR_MODEL=
# QWEN_BUILDER_MODEL=
